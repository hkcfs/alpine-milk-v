# Slim arm64 config fragment for Milk-V Duo 256M (SG2002 / Cortex-A53)
#
# Applied on top of the upstream arm64 `defconfig` (after disabling all
# non-Sophgo SoC vendor families in build.sh). Goal: drop the heavy driver
# subsystems a headless SBC image never uses, so the kernel compiles in a
# fraction of the time. Inspired by the scpcom/sophgo-sg200x SDK, which only
# builds a single SoC family instead of every arm64 vendor.
#
# Essentials for boot (serial 8250/dw + PL011, MMC/SDHCI, STMMAC ethernet,
# ext4/vfat, virtio, GIC, arch timer, USB core) are intentionally NOT touched
# here - they stay enabled from the base defconfig.

# --- GPU / display stack (largest single compile-time sink) ---
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_BACKLIGHT_CLASS_DEVICE is not set
# CONFIG_LOGO is not set

# --- Audio ---
# CONFIG_SOUND is not set
# CONFIG_SND is not set

# --- Media (V4L2 / DVB / cameras / codecs) ---
# CONFIG_MEDIA_SUPPORT is not set

# --- RDMA / InfiniBand ---
# CONFIG_INFINIBAND is not set

# --- Wireless (Duo 256M has no onboard WiFi) ---
# CONFIG_WLAN is not set
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set

# --- Virtualization host/guest extras (not needed on the SoC) ---
# CONFIG_KVM is not set
# CONFIG_XEN is not set
# CONFIG_HYPERV is not set

# --- Vendor staging drivers ---
# CONFIG_STAGING is not set

# --- Extra filesystems (keep ext4 + vfat + tmpfs only) ---
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_GFS2_FS is not set
# CONFIG_OCFS2_FS is not set
# CONFIG_NILFS2_FS is not set
# CONFIG_F2FS_FS is not set
# CONFIG_JFS_FS is not set
# CONFIG_REISERFS_FS is not set
# CONFIG_NTFS3_FS is not set

# --- Legacy / niche networking ---
# CONFIG_HAMRADIO is not set
# CONFIG_CAN is not set
# CONFIG_6LOWPAN is not set

# --- Misc large drivers unused on this board ---
# CONFIG_ATA is not set
# CONFIG_SCSI_FC_ATTRS is not set
# CONFIG_TARGET_CORE is not set
# CONFIG_NVME_CORE is not set
